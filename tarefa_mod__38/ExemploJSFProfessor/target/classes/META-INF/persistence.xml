<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2" xmlns="http://jcp.org">
    <persistence-unit name="ExemploJPA">
        <provider>org.hibernate.ejb.HibernatePersistence</provider>
        <class>br.com.rpires.domain.Carro</class>
        <properties>
            <property name="javax.persistence.jdbc.driver" value="org.postgresql.Driver" />
            <property name="javax.persistence.jdbc.url" value="jdbc:postgresql://localhost:15432/vendas_online" />
            <property name="javax.persistence.jdbc.user" value="postgres" />
            <property name="javax.persistence.jdbc.password" value="admin" />
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update" />
            <property name="hibernate.show_sql" value="true" />
        </properties>
    </persistence-unit>
</persistence>